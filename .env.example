# --- Database (Turso / libSQL) ---
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM=Wills Transfer <orders@yourdomain.ca>
ORDER_NOTIFY_TO=cs@safetyhouse.ca

# --- Payments (Stripe) ---
# Secret key (test: sk_test_..., live: sk_live_...)
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret for the /api/stripe-webhook endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_...

# Public origin used to build Stripe success/cancel URLs. Optional — defaults to
# the request origin. Set it if you're behind a proxy or want to force https.
# SITE_URL=https://apparel.yourdomain.ca

# NOTE: the older VITE_-prefixed names (VITE_TURSO_URL, VITE_RESEND_API_KEY, ...)
# are still read as fallbacks for backward compatibility.
